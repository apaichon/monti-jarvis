APP_ENV=dev
PORT=8091
DEMO_TENANT_ID=demo
AUTH_DISABLED=true
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
AUTH_CACHE_ENABLED=true
AUTH_WRITE_BEHIND_ENABLED=true
AUTH_EVENTS_ENABLED=true
AUTH_USER_CACHE_TTL=15m
LEGACY_UI_ENABLED=false
CUSTOMER_WEB_DIR=apps/customer-web/build

NATS_URL=nats://localhost:4222
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_EMBED_MODEL=gemini-embedding-001

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/monti_jarvis?sslmode=disable
POSTGRES_ADMIN_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
POSTGRES_SCHEMA=callcenter

REDIS_URL=redis://localhost:6379/4
REDIS_PREFIX=monti_jarvis:

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=monti-jarvis
MINIO_PREFIX=calls/
MINIO_USE_SSL=false

CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=monti_jarvis
CLICKHOUSE_USER=monti
CLICKHOUSE_PASSWORD=monti

# Mobile Call API and SDK (SPRINT-027)
MOBILE_CALL_API_ENABLED=false
MOBILE_WS_MAX_FRAME_BYTES=32768
MOBILE_PUSH_ENABLED=false
MOBILE_PUSH_PROVIDER=auto
MOBILE_PUSH_TOKEN_TTL=15m

# Cross-tenant audit log (SPRINT-028)
AUDIT_LOG_MODE=spool
AUDIT_LOG_DIR=./var/audit
AUDIT_LOG_FLUSH_INTERVAL=5s
AUDIT_LOG_RETENTION=1h
AUDIT_LOG_BATCH_SIZE=500
AUDIT_LOG_QUEUE_SIZE=10000
AUDIT_LOG_RETRY_BACKOFF=1s
