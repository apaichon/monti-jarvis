APP_ENV=dev
PORT=8091
DEMO_TENANT_ID=demo
AUTH_DISABLED=true
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
AUTH_CACHE_ENABLED=true
AUTH_WRITE_BEHIND_ENABLED=true
AUTH_EVENTS_ENABLED=true
AUTH_USER_CACHE_TTL=15m
LEGACY_UI_ENABLED=false
CUSTOMER_WEB_DIR=apps/customer-web/build
PLATFORM_ADMIN_WEB_DIR=apps/platform-admin-web/build
TENANT_WEB_DIR=apps/tenant-web/build
TENANT_REGISTER_ENABLED=true
TENANT_REGISTER_RATE_LIMIT=5
APP_PUBLIC_URL=http://monti-jarvis-dev.local:8091
# Resend transactional email (tenant verify / KYC). Domain on FROM must be verified at resend.com/domains.
RESEND_ENABLED=true
RESEND_API_KEY=
# Either full From header:
RESEND_FROM_EMAIL=Monti <no-reply@your-verified-domain.com>
# Or address + display name (also supported):
# RESEND_FROM_ADDR=no-reply@your-verified-domain.com
# RESEND_FROM_NAME=Monti
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

NATS_URL=nats://localhost:4222
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_EMBED_MODEL=gemini-embedding-001
VOICE=Aoede

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/monti_jarvis?sslmode=disable
POSTGRES_ADMIN_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
POSTGRES_SCHEMA=callcenter

REDIS_URL=redis://localhost:6379/4
REDIS_PREFIX=monti_jarvis:

# Quota & rate limit (SPRINT-013) — Redis counters; month windows are UTC
# Keys: {REDIS_PREFIX}quota:{tenant}:concurrent | minutes:{YYYYMM}
#       {REDIS_PREFIX}rl:{tenant}:chat|km|voice:{YYYYMMDDHHMM}
QUOTA_ENABLED=true
QUOTA_FAIL_OPEN=true
QUOTA_CONCURRENT_TTL=2h
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT_PER_MIN=60
RATE_LIMIT_KM_PER_MIN=30
RATE_LIMIT_VOICE_PER_MIN=20

# Embed to Web (SPRINT-014) — empty allowlist permits any Origin when true
EMBED_ALLOW_EMPTY_ORIGINS=true

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=monti-jarvis
MINIO_PREFIX=calls/
MINIO_USE_SSL=false

CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=monti_jarvis
CLICKHOUSE_USER=monti
CLICKHOUSE_PASSWORD=monti

# ChillPay sandbox (SPRINT-008) — optional; mock provider works without keys
CHILLPAY_MERCHANT_CODE=
CHILLPAY_API_KEY=
CHILLPAY_MD5_KEY=
CHILLPAY_BASE_URL=https://sandbox-appsrv2.chillpay.co/api/v2/Payment
CHILLPAY_ROUTE_NO=1
CHILLPAY_CURRENCY=764
# Public URLs ChillPay can reach (ngrok or APP_PUBLIC_URL host)
CHILLPAY_CALLBACK_URL=
# Server callback (server-to-server). Path must be /api/callbacks/chillpay
CHILLPAY_CALLBACK_URL=http://localhost:8091/api/callbacks/chillpay
# Browser return host (path forced to /api/callbacks/chillpay/return → SPA /tenant/billing/return)
CHILLPAY_RETURN_URL=http://localhost:8091/tenant/billing/return
PAYMENT_CALLBACK_DEV_BYPASS=false