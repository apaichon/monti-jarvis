# Optional operations group loaded when CONFIG_GROUPS includes ops.
AUDIT_LOG_MODE=spool
AUDIT_LOG_DIR=./var/audit
AUDIT_LOG_FLUSH_INTERVAL=5s
AUDIT_LOG_RETENTION=1h
AUDIT_LOG_BATCH_SIZE=500
AUDIT_LOG_QUEUE_SIZE=10000
AUDIT_LOG_RETRY_BACKOFF=1s
QUOTA_ENABLED=true
QUOTA_FAIL_OPEN=true
RATE_LIMIT_ENABLED=true
